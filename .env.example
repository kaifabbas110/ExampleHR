# Application
NODE_ENV=development
PORT=3000
APP_NAME=readyon-time-off-service

# Database
DB_PATH=./data/readyon.db

# HCM Integration
HCM_BASE_URL=http://localhost:3000/mock-hcm
HCM_API_KEY=mock-hcm-api-key
HCM_TIMEOUT_MS=5000
HCM_MAX_RETRIES=3
HCM_RETRY_BASE_DELAY_MS=500
HCM_RETRY_MAX_DELAY_MS=5000

# Sync Configuration
SYNC_CRON_SCHEDULE=*/15 * * * *
SYNC_ENABLED=true

# Balance Staleness Thresholds (milliseconds)
BALANCE_STALE_THRESHOLD_MS=900000
BALANCE_MAX_ACCEPTABLE_STALE_MS=3600000

# Mock HCM Configuration
MOCK_HCM_FAILURE_RATE=0.2
MOCK_HCM_MIN_DELAY_MS=50
MOCK_HCM_MAX_DELAY_MS=500
